# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE / editor files
.vscode/
.idea/
*.iml

# OS and logs
.DS_Store
Thumbs.db
*.log

# Local output artifacts
output/
exports/
snapshots/

